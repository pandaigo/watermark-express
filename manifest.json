{
  "manifest_version": 3,
  "name": "Watermark Express — Quick Bulk Image Watermarking",
  "version": "1.0.0",
  "description": "Add text & logo watermarks to your images instantly. Bulk processing, custom positioning, and one-click download. One-time purchase, no subscription.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Open Watermark Express",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://extensionpay.com/*"],
      "js": ["ExtPay.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "open-editor": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Watermark Express"
    }
  }
}
